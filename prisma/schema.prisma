generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String           @id @default(uuid())
  user_id        String           @unique
  money          Int              @default(0)
  ruby           Int              @default(0)
  defense        Int              @default(0)
  documents      Int              @default(0)
  lang           Lang             @default(eng)
  user_equipment User_equipment[]
}

model User_equipment {
  id     String  @id @default(uuid())
  name   String
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Game {
  id        String   @id @default(uuid())
  chat_id   String   @unique
  status    Status   @default(LOBBY)
  lobby_msg Int?
  createdAt DateTime @default(now())

  startedAt        DateTime?
  phase            Phase     @default(DAY)
  dayNumber        Int       @default(0)
  lastTransitionAt DateTime?

  players GamePlayer[]
}

model GamePlayer {
  id         String  @id @default(uuid())
  gameId     String
  telegramId String
  firstName  String
  username   String?
  role       String?
  isAlive    Boolean @default(true)

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([gameId, telegramId])
}

enum Status {
  LOBBY
  RUNNING
  FINISHED
}

enum Phase {
  DAY
  NIGHT
  VOTING
}

enum Lang {
  eng
  uz
  ru
}
