generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id      String @id @default(uuid())
  user_id String @unique
  money   Int    @default(0)
  diamond Int    @default(0)
  role    String @default("")
}

model Game {
  id       String @id @default(uuid())
  userTgId String @unique
  role     String @default("")
}

enum Status {
  LOBBY
  RUNNING
  FINISHED
}

enum Phase {
  DAY
  NIGHT
  VOTING
}

enum Lang {
  eng
  uz
  ru
}
