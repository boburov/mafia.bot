generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id      String @id @default(uuid())
  user_id String @unique
  money   Int    @default(0)
  diamond Int    @default(0)
  role    String @default("")
}

model Chanel {
  id        String @id @default(uuid())
  chat_name String
}

model Game {
  id      String   @id @default(uuid())
  chatId  String
  status  Status   @default(LOBBY)
  phase   Phase    @default(DAY)
  players Player[]
}

model Player {
  id       String @id @default(uuid())
  userTgId String
  role     String @default("")

  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  gameId String

  @@unique([userTgId, gameId])
}

enum Status {
  LOBBY
  RUNNING
  FINISHED
}

enum Phase {
  DAY
  NIGHT
  VOTING
}

enum Lang {
  eng
  uz
  ru
}
