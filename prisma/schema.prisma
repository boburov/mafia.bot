generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String           @id @default(uuid())
  user_id        String           @unique
  money          Int              @default(0)
  ruby           Int              @default(0)
  defense        Int              @default(0)
  documents      Int              @default(0)
  lang           Lang             @default(eng)
  user_equipment User_equipment[]
}

model User_equipment {
  id     String  @id @default(uuid())
  name   String
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Game {
  id      String       @id @default(uuid())
  phase   Phase        @default(DAY)
  status  Status       @default(LOBBY)
  chat_id String       @unique
  players GamePlayer[]
}

model GamePlayer {
  id     String  @id @default(uuid())
  userId String
  gameId String
  role   String?
  game   Game    @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([gameId, userId])
}

enum Status {
  FINISHED
  RUNNING
  LOBBY
}

enum Phase {
  DAY
  NIGHT
  VOTING
}

enum Lang {
  eng
  uz
  ru
}
